root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Markdown: keep trailing whitespace — two trailing spaces are a line break.
[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json,toml,cff}]
indent_size = 2

[*.{js,jsx,ts,tsx,html,css,scss,svg}]
indent_size = 2

[Makefile]
indent_style = tab
